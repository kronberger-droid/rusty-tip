#!/usr/bin/env bash
# Pre-push hook: refuse to push unless the tree is rustfmt-clean.
#
# Formatting width is pinned by the project rustfmt.toml (max_width = 100),
# which shadows any personal ~/.rustfmt.toml, so this checks at 100 columns
# regardless of your global config.
#
# Activate (once per clone):   git config core.hooksPath .githooks
# Bypass for one push:         git push --no-verify
set -uo pipefail

if ! command -v cargo >/dev/null 2>&1; then
  echo "pre-push: cargo not found on PATH; skipping fmt check (run 'nix develop')." >&2
  exit 0
fi

echo "pre-push: checking formatting (cargo fmt --all --check)…"
if ! cargo fmt --all --check; then
  echo >&2
  echo "pre-push: formatting check failed — run 'cargo fmt --all' to fix, then push again." >&2
  echo "          (one-off bypass: git push --no-verify)" >&2
  exit 1
fi
echo "pre-push: formatting OK."
